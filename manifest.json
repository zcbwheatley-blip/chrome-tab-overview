{
  "manifest_version": 3,
  "name": "Tab Overview",
  "version": "1.0.0",
  "description": "Kanban-style tab manager with domain grouping and search",

  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "favicon"
  ],

  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },

  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Tab Overview"
  },

  "chrome_url_overrides": {
    "newtab": "overview/overview.html"
  },

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Open Tab Overview"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
